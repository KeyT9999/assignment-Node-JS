{
  "info": {
    "name": "05_EquipmentRental",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:9999"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "admin_token",
      "value": ""
    },
    {
      "key": "equipment_id",
      "value": ""
    },
    {
      "key": "rental_id",
      "value": ""
    },
    {
      "key": "user_id",
      "value": ""
    },
    {
      "key": "record_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Register Customer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"newcustomer\",\"password\":\"123456\"}"
        },
        "url": "{{base_url}}/auth/register"
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"user1\",\"password\":\"123456\"}"
        },
        "url": "{{base_url}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.set('token', pm.response.json().token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Login Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"admin1\",\"password\":\"123456\"}"
        },
        "url": "{{base_url}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.set('admin_token', pm.response.json().token);"
            ]
          }
        }
      ]
    },
    {
      "name": "List Equipment",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/equipment"
      }
    },
    {
      "name": "Admin List Users",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": "{{base_url}}/users"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const users = pm.response.json();",
              "if (Array.isArray(users) && users.length) pm.collectionVariables.set('user_id', users[users.length - 1]._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin Delete User",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": "{{base_url}}/users/{{user_id}}"
      }
    },
    {
      "name": "Create Rental",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"equipmentId\":\"{{equipment_id}}\",\"startDate\":\"2026-08-01\",\"endDate\":\"2026-08-03\",\"quantity\":2}"
        },
        "url": "{{base_url}}/rentals"
      }
    },
    {
      "name": "Get Rentals",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/rentals"
      }
    },
    {
      "name": "Return Equipment",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": "{{base_url}}/rentals/{{rental_id}}/return"
      }
    },
    {
      "name": "Search Rentals By Date",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/rentalsByDate?start=2026-01-01&end=2026-12-31"
      }
    },
    {
      "name": "Generated endpoint coverage",
      "item": [
        {
          "name": "03 POST /equipment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/equipment",
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}