{
  "info": {
    "name": "03_MovieTheaterBooking",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:9999"
    },
    {
      "key": "booking_id",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Get Theaters",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/theaters"
      }
    },
    {
      "name": "Get Schedules",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/schedules"
      }
    },
    {
      "name": "Get Bookings",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/bookings"
      }
    },
    {
      "name": "Create Booking",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"customerName\":\"Nguyen Van A\",\"theaterName\":\"Cineplex Downtown\",\"movieName\":\"Inception\",\"showTime\":\"2027-05-15T20:00:00Z\",\"numberOfTickets\":2}"
        },
        "url": "{{base_url}}/bookings"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if(pm.response.code===201) pm.collectionVariables.set('booking_id',pm.response.json()._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Update Booking",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"numberOfTickets\":3}"
        },
        "url": "{{base_url}}/bookings/{{booking_id}}"
      }
    },
    {
      "name": "Cancel Booking",
      "request": {
        "method": "DELETE",
        "url": "{{base_url}}/bookings/{{booking_id}}"
      }
    }
  ]
}