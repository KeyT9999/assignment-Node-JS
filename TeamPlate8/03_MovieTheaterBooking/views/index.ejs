<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title><%= title %></title><style>body{font-family:Arial;max-width:1050px;margin:30px auto;padding:0 15px}form{display:grid;grid-template-columns:repeat(5,1fr);gap:8px}input,select,button{padding:9px}table{width:100%;border-collapse:collapse;margin-top:20px}td,th{border:1px solid #ddd;padding:8px}.error{color:#b00020}</style></head><body><h1><%= title %></h1><form id="form"><input name="customerName" placeholder="Customer" required><select name="schedule" id="schedule" required></select><input name="numberOfTickets" type="number" min="1" placeholder="Tickets" required><button>Book tickets</button></form><p id="message" class="error"></p><table><thead><tr><th>Customer</th><th>Movie</th><th>Theater</th><th>Tickets</th><th>Total</th><th></th></tr></thead><tbody id="rows"></tbody></table><script>
let schedules=[];const money=n=>new Intl.NumberFormat('en-US',{style:'currency',currency:'USD'}).format(n);async function load(){schedules=await fetch('/schedules').then(r=>r.json());schedule.innerHTML=schedules.map((s,i)=>`<option value="${i}">${s.movieName} — ${s.theaterName} — ${new Date(s.showTime).toLocaleString()} (${s.availableSeats} seats)</option>`).join('');const bookings=await fetch('/bookings').then(r=>r.json());rows.innerHTML=bookings.map(b=>`<tr><td>${b.customerName}</td><td>${b.movieName}</td><td>${b.theaterName}</td><td>${b.numberOfTickets}</td><td>${money(b.totalAmount)}</td><td><button onclick="cancelBooking('${b._id}')">Cancel</button></td></tr>`).join('')}form.addEventListener('submit',async e=>{e.preventDefault();const raw=Object.fromEntries(new FormData(form));const s=schedules[Number(raw.schedule)];const body={customerName:raw.customerName,theaterName:s.theaterName,movieName:s.movieName,showTime:s.showTime,numberOfTickets:Number(raw.numberOfTickets)};const r=await fetch('/bookings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)}),data=await r.json();message.textContent=r.ok?'Booking created':data.message;if(r.ok){form.reset();load()}});async function cancelBooking(id){await fetch('/bookings/'+id,{method:'DELETE'});load()}load();
</script></body></html>
