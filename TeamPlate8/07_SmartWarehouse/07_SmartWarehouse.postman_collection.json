{
  "info": {
    "name": "07_SmartWarehouse WarePro",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:9999"
    },
    {
      "key": "manager_token",
      "value": ""
    },
    {
      "key": "keeper_token",
      "value": ""
    },
    {
      "key": "auditor_token",
      "value": ""
    },
    {
      "key": "product_id",
      "value": ""
    },
    {
      "key": "warehouse_1",
      "value": ""
    },
    {
      "key": "warehouse_2",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "warehouse_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Login Manager",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"manager1\",\"password\":\"123456\"}"
        },
        "url": "{{base_url}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.set('manager_token',pm.response.json().token)"
            ]
          }
        }
      ]
    },
    {
      "name": "Login Keeper",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"keeper1\",\"password\":\"123456\"}"
        },
        "url": "{{base_url}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.set('keeper_token',pm.response.json().token)"
            ]
          }
        }
      ]
    },
    {
      "name": "Low Stock Products",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{auditor_token}}"
          }
        ],
        "url": "{{base_url}}/products?lowStock=true"
      }
    },
    {
      "name": "Import",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{keeper_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"productId\":\"{{product_id}}\",\"warehouseId\":\"{{warehouse_1}}\",\"quantity\":10,\"unitPrice\":500000}"
        },
        "url": "{{base_url}}/transactions/import"
      }
    },
    {
      "name": "Export",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{keeper_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"productId\":\"{{product_id}}\",\"warehouseId\":\"{{warehouse_1}}\",\"quantity\":5,\"unitPrice\":500000}"
        },
        "url": "{{base_url}}/transactions/export"
      }
    },
    {
      "name": "Transfer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{manager_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"productId\":\"{{product_id}}\",\"sourceWarehouseId\":\"{{warehouse_1}}\",\"destinationWarehouseId\":\"{{warehouse_2}}\",\"quantity\":5}"
        },
        "url": "{{base_url}}/transactions/transfer"
      }
    },
    {
      "name": "Stock Summary",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{manager_token}}"
          }
        ],
        "url": "{{base_url}}/reports/stock-summary"
      }
    },
    {
      "name": "Transaction Report",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{manager_token}}"
          }
        ],
        "url": "{{base_url}}/reports/transactions?type=transfer_out"
      }
    },
    {
      "name": "Generated endpoint coverage",
      "item": [
        {
          "name": "02 POST /auth/register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"testuser\", \"password\": \"123456\", \"fullName\": \"Test User\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "03 POST /products",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/products",
            "body": {
              "mode": "raw",
              "raw": "{\"sku\": \"test-value\", \"name\": \"Test record\", \"category\": \"test-value\", \"unit\": \"test-value\", \"unitPrice\": 1, \"reorderLevel\": 1}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}