<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title><%= title %></title><style>body{font-family:Arial;max-width:1000px;margin:30px auto;padding:0 16px}form{display:grid;grid-template-columns:repeat(5,1fr);gap:8px}input,button{padding:9px}table{width:100%;border-collapse:collapse;margin-top:20px}th,td{border:1px solid #ddd;padding:8px}.error{color:#b00020}</style></head><body>
<h1><%= title %></h1><form id="bookingForm"><input name="customerName" placeholder="Customer name" required><input name="carNumber" placeholder="Car number" required><input name="startDate" type="date" required><input name="endDate" type="date" required><button>Create booking</button></form><p id="message" class="error"></p>
<h2>Cars</h2><div id="cars"></div><h2>Bookings</h2><table><thead><tr><th>Customer</th><th>Car</th><th>Start</th><th>End</th><th>Total</th><th></th></tr></thead><tbody id="bookings"></tbody></table>
<script>
const money=n=>new Intl.NumberFormat('vi-VN').format(n); async function load(){const [cars,bookings]=await Promise.all([fetch('/cars').then(r=>r.json()),fetch('/bookings').then(r=>r.json())]);document.querySelector('#cars').textContent=cars.map(c=>`${c.carNumber} (${c.status}) - ${money(c.pricePerDay)}/day`).join(' | ');document.querySelector('#bookings').innerHTML=bookings.map(b=>`<tr><td>${b.customerName}</td><td>${b.carNumber}</td><td>${new Date(b.startDate).toLocaleDateString()}</td><td>${new Date(b.endDate).toLocaleDateString()}</td><td>${money(b.totalAmount)}</td><td><button onclick="removeBooking('${b._id}')">Delete</button></td></tr>`).join('')}
document.querySelector('#bookingForm').addEventListener('submit',async e=>{e.preventDefault();const body=Object.fromEntries(new FormData(e.target));const r=await fetch('/bookings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});const data=await r.json();document.querySelector('#message').textContent=r.ok?'Booking created':data.message;if(r.ok){e.target.reset();load()}});async function removeBooking(id){await fetch('/bookings/'+id,{method:'DELETE'});load()}load();
</script></body></html>
