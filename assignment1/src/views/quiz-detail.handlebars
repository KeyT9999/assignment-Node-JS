<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>SimpleQuiz - Chi Tiết Quiz</title>
  <style>
    :root {
      --color-electric-lime: #beff50;
      --color-near-black: #14140f;
      --color-pure-black: #000000;
      --color-pure-white: #ffffff;
      --color-warm-cream: #f5f5eb;
      --color-parchment-card: #fafaf5;
      --color-stone: #d2d2c8;
      --color-graphite: #6e6e64;
      --color-coral-alert: #eb3131;
      --color-mint-confirm: #1dc479;

      --font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: var(--font-family);
    }

    body {
      background-color: var(--color-warm-cream);
      color: var(--color-near-black);
      margin: 0;
      padding: 40px 20px;
      line-height: 1.5;
    }

    .container {
      max-width: 800px;
      margin: 0 auto;
      background: var(--color-pure-white);
      padding: 40px;
      border-radius: 26px;
      border: 1px solid var(--color-stone);
    }

    h1 {
      font-size: 32px;
      font-weight: 500;
      color: var(--color-near-black);
      margin-top: 0;
      margin-bottom: 24px;
      letter-spacing: -0.02em;
    }

    h2 {
      font-size: 24px;
      font-weight: 500;
      color: var(--color-near-black);
      margin: 0 0 12px 0;
    }

    h3 {
      font-size: 20px;
      font-weight: 500;
      color: var(--color-near-black);
      margin: 0;
    }

    .nav {
      display: flex;
      gap: 8px;
      margin-bottom: 32px;
      background: var(--color-parchment-card);
      padding: 8px;
      border-radius: 26px;
      border: 1px solid var(--color-stone);
      width: fit-content;
    }

    .nav a {
      text-decoration: none;
      color: var(--color-near-black);
      font-weight: 500;
      padding: 8px 20px;
      border-radius: 26px;
      font-size: 14px;
      transition: background-color 0.2s, color 0.2s;
    }

    .nav a:hover {
      background: rgba(20, 20, 15, 0.05);
    }

    .nav a.active {
      background: var(--color-near-black);
      color: var(--color-pure-white);
    }

    .toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      gap: 16px;
    }

    .search-input {
      flex: 1;
      padding: 12px 20px;
      border: 1px solid var(--color-stone);
      border-radius: 26px;
      background: var(--color-pure-white);
      color: var(--color-near-black);
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s;
    }

    .search-input:focus {
      border-color: var(--color-near-black);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 24px;
      border: 1px solid var(--color-near-black);
      border-radius: 26px;
      cursor: pointer;
      font-weight: 500;
      font-size: 14px;
      text-decoration: none;
      transition: background-color 0.2s, color 0.2s;
    }

    .btn-primary {
      background-color: var(--color-electric-lime);
      color: var(--color-near-black);
    }

    .btn-primary:hover {
      background-color: #aae045;
    }

    .btn-secondary {
      background-color: var(--color-pure-white);
      color: var(--color-near-black);
      border: 1px solid var(--color-stone);
    }

    .btn-secondary:hover {
      background-color: var(--color-parchment-card);
    }

    .btn-danger {
      background-color: var(--color-pure-white);
      color: var(--color-coral-alert);
      border: 1px solid var(--color-coral-alert);
    }

    .btn-danger:hover {
      background-color: rgba(235, 49, 49, 0.08);
    }

    .btn-accent {
      background-color: var(--color-near-black);
      color: var(--color-pure-white);
      border: 1px solid var(--color-near-black);
    }

    .btn-accent:hover {
      background-color: var(--color-charcoal);
    }

    .btn-outline {
      background-color: var(--color-pure-white);
      color: var(--color-near-black);
      border: 1px solid var(--color-stone);
    }

    .btn-outline:hover {
      background-color: var(--color-parchment-card);
    }

    .btn-outline.active {
      background-color: var(--color-near-black);
      color: var(--color-pure-white);
      border-color: var(--color-near-black);
    }

    .back-btn {
      display: inline-flex;
      margin-bottom: 24px;
      color: var(--color-graphite);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
    }

    .back-btn:hover {
      color: var(--color-near-black);
      text-decoration: underline;
    }

    .quiz-header-info {
      background: var(--color-parchment-card);
      padding: 24px;
      border: 1px solid var(--color-stone);
      margin-bottom: 32px;
      border-radius: 26px;
    }

    .quiz-header-info p {
      margin: 0;
      color: var(--color-graphite);
      font-size: 14px;
    }

    .quiz-list, .question-list {
      margin-top: 24px;
    }

    .quiz-card {
      border: 1px solid var(--color-stone);
      padding: 24px;
      margin-bottom: 16px;
      border-radius: 26px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: var(--color-parchment-card);
      transition: border-color 0.2s;
    }

    .quiz-card:hover {
      border-color: var(--color-near-black);
    }

    .quiz-info h3 {
      margin: 0 0 8px 0;
      color: var(--color-near-black);
    }

    .quiz-info p {
      margin: 0 0 12px 0;
      color: var(--color-graphite);
      font-size: 14px;
    }

    .quiz-info span {
      font-size: 12px;
      color: var(--color-graphite);
      background: var(--color-pure-white);
      padding: 4px 10px;
      border-radius: 8px;
      border: 1px solid var(--color-stone);
      display: inline-block;
    }

    .quiz-actions, .actions-group {
      display: flex;
      gap: 8px;
    }

    .question-card {
      border: 1px solid var(--color-stone);
      padding: 24px;
      margin-bottom: 16px;
      border-radius: 26px;
      background: var(--color-parchment-card);
    }

    .question-card h4 {
      margin: 0 0 16px 0;
      font-size: 16px;
      color: var(--color-near-black);
      font-weight: 500;
    }

    .options-list {
      list-style-type: none;
      padding-left: 0;
      margin: 0 0 16px 0;
    }

    .option-item {
      padding: 10px 16px;
      border: 1px solid var(--color-stone);
      margin-bottom: 8px;
      border-radius: 26px;
      font-size: 14px;
      background: var(--color-pure-white);
      color: var(--color-near-black);
    }

    .option-item.correct {
      background-color: #d1fae5;
      border-color: var(--color-mint-confirm);
      color: #065f46;
      font-weight: 500;
    }

    .question-footer {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: var(--color-graphite);
      align-items: center;
      border-top: 1px solid var(--color-stone);
      padding-top: 16px;
      margin-top: 8px;
    }

    .btn-link {
      background: none;
      border: none;
      color: var(--color-near-black);
      cursor: pointer;
      font-size: 12px;
      font-weight: 500;
      text-decoration: underline;
    }

    .btn-link:hover {
      color: var(--color-pure-black);
    }

    .btn-link-danger {
      color: var(--color-coral-alert);
    }

    .btn-link-danger:hover {
      color: #b91c1c;
    }

    /* Modal */
    .modal-overlay {
      display: none;
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(20, 20, 15, 0.4);
      justify-content: center;
      align-items: center;
      z-index: 1000;
    }

    .modal {
      background: var(--color-pure-white);
      padding: 32px;
      border-radius: 26px;
      width: 480px;
      max-height: 90vh;
      overflow-y: auto;
      border: 1px solid var(--color-stone);
    }

    .modal h3 {
      font-size: 24px;
      margin-bottom: 20px;
      font-weight: 500;
    }

    .form-group {
      margin-bottom: 20px;
    }

    .form-group label {
      display: block;
      margin-bottom: 8px;
      font-weight: 500;
      font-size: 14px;
      color: var(--color-near-black);
    }

    .form-group input, .form-group textarea {
      width: 100%;
      padding: 12px 20px;
      border: 1px solid var(--color-stone);
      border-radius: 26px;
      box-sizing: border-box;
      font-size: 14px;
      color: var(--color-near-black);
      background: var(--color-pure-white);
      outline: none;
    }

    .form-group input:focus, .form-group textarea:focus {
      border-color: var(--color-near-black);
    }

    .option-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }

    .option-radio {
      cursor: pointer;
      width: 20px;
      height: 20px;
      accent-color: var(--color-near-black);
    }

    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 12px;
      margin-top: 24px;
    }
  </style>
</head>
<body>

  <div class="container">
    <h1>Chi Tiết Bộ Quiz</h1>
    
    <div class="nav">
      <a href="/">Quản Lý Quiz</a>
      <a href="/pages/questions">Ngân Hàng Câu Hỏi</a>
    </div>

    <a href="/" class="back-btn">&larr; Quay lại danh sách Quiz</a>

    <div class="quiz-header-info" id="quiz-info">
      <p>Đang tải thông tin Quiz...</p>
    </div>

    <div class="toolbar">
      <h3>Danh Sách Câu Hỏi</h3>
      <div style="display: flex; gap: 8px;">
        <button class="btn btn-outline" id="btn-filter-capital" onclick="toggleCapitalFilter()">Lọc "Capital"</button>
        <button class="btn btn-primary" onclick="openAddQuestionModal()">Thêm Câu Hỏi</button>
        <button class="btn btn-accent" onclick="openAddManyModal()">Thêm Hàng Loạt (Array)</button>
      </div>
    </div>

    <div class="question-list" id="questions-grid">
      <p style="text-align: center; color: #666;">Đang tải câu hỏi...</p>
    </div>
  </div>

  <!-- Add 1 Question Modal -->
  <div class="modal-overlay" id="q-modal">
    <div class="modal">
      <h3 style="margin-top:0;">Thêm Câu Hỏi Mới</h3>
      <form id="q-form">
        <div class="form-group">
          <label>Nội dung câu hỏi</label>
          <input type="text" id="q-text-input" required placeholder="Nhập câu hỏi...">
        </div>
        <div class="form-group">
          <label>Các phương án (Tích chọn đáp án đúng)</label>
          <div class="option-row">
            <input type="radio" name="correct-opt" value="0" checked class="option-radio">
            <input type="text" id="opt-0" required placeholder="Đáp án A">
          </div>
          <div class="option-row">
            <input type="radio" name="correct-opt" value="1" class="option-radio">
            <input type="text" id="opt-1" required placeholder="Đáp án B">
          </div>
          <div class="option-row">
            <input type="radio" name="correct-opt" value="2" class="option-radio">
            <input type="text" id="opt-2" required placeholder="Đáp án C">
          </div>
          <div class="option-row">
            <input type="radio" name="correct-opt" value="3" class="option-radio">
            <input type="text" id="opt-3" required placeholder="Đáp án D">
          </div>
        </div>
        <div class="form-group">
          <label>Từ khóa (Phân cách bởi dấu phẩy)</label>
          <input type="text" id="q-keywords-input" placeholder="Ví dụ: capital, history, asia">
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="closeAddQuestionModal()">Hủy</button>
          <button type="submit" class="btn btn-primary">Lưu</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Add Many Questions Modal -->
  <div class="modal-overlay" id="many-modal">
    <div class="modal">
      <h3 style="margin-top:0;">Thêm Hàng Loạt Câu Hỏi</h3>
      <form id="many-form">
        <div class="form-group">
          <label>Dữ liệu JSON Array</label>
          <textarea id="json-textarea" rows="12" style="font-family: monospace;" required></textarea>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="closeAddManyModal()">Hủy</button>
          <button type="submit" class="btn btn-primary">Lưu Danh Sách</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Nhận ID của bộ Quiz từ server-side thông thông qua render context (Handlebars token)
    const quizId = '{{ quizId }}';
    // Biến lưu trữ dữ liệu chi tiết bộ Quiz
    let quizData = null;
    // Biến trạng thái xác định có đang bật bộ lọc các câu hỏi chứa từ khoá "capital" hay không
    let isFilterCapital = false;

    // Biểu mẫu JSON mẫu hiển thị mặc định trong khung textarea Thêm hàng loạt câu hỏi
    const defaultJSONTemplate = [
      {
        "text": "What is the capital of Japan?",
        "options": ["Tokyo", "Kyoto", "Osaka", "Hiroshima"],
        "correctAnswerIndex": 0,
        "keywords": ["capital", "asia", "japan"]
      },
      {
        "text": "What is the capital of Vietnam?",
        "options": ["Ho Chi Minh", "Hanoi", "Da Nang", "Hue"],
        "correctAnswerIndex": 1,
        "keywords": ["capital", "vietnam", "asia"]
      }
    ];

    // Sự kiện DOMContentLoaded: Khởi chạy sau khi trang đã tải xong
    document.addEventListener('DOMContentLoaded', () => {
      fetchQuizDetails(); // Lấy chi tiết bộ Quiz
      // Gán JSON mẫu vào ô textarea
      document.getElementById('json-textarea').value = JSON.stringify(defaultJSONTemplate, null, 2);
    });

    // Hàm gọi API lấy thông tin chi tiết bộ Quiz kèm danh sách câu hỏi
    function fetchQuizDetails() {
      // Nếu bật lọc "capital", gọi API `/populate`, ngược lại gọi API thông thường
      const url = isFilterCapital ? `/quizzes/${quizId}/populate` : `/quizzes/${quizId}`;
      fetch(url)
        .then(res => res.json())
        .then(res => {
          if (res.success) {
            quizData = res.data;
            renderQuizHeader(); // Hiển thị thông tin tiêu đề, mô tả của Quiz
            renderQuestions(quizData.questions); // Hiển thị danh sách câu hỏi
          } else {
            alert('Lỗi: ' + res.message);
          }
        });
    }

    // Hiển thị phần thông tin giới thiệu bộ Quiz (Tiêu đề, mô tả, số lượng câu hỏi)
    function renderQuizHeader() {
      const headerBox = document.getElementById('quiz-info');
      headerBox.innerHTML = `
        <h2>${quizData.title}</h2>
        <p>${quizData.description}</p>
        <p style="font-size:12px; margin-top:5px; color:#888;">Số câu hỏi: ${quizData.questions ? quizData.questions.length : 0}</p>
      `;
    }

    // Hiển thị danh sách câu hỏi liên kết trong bộ Quiz lên giao diện
    function renderQuestions(questions) {
      const grid = document.getElementById('questions-grid');
      if (!questions || questions.length === 0) {
        grid.innerHTML = '<p style="text-align:center; color:#888;">Không có câu hỏi nào được liên kết.</p>';
        return;
      }

      grid.innerHTML = questions.map((q, idx) => {
        if (!q) return '';
        return `
          <div class="question-card">
            <h4>Câu ${idx + 1}: ${q.text}</h4>
            <ul class="options-list">
              ${q.options.map((opt, oIdx) => {
                const isCorrect = oIdx === q.correctAnswerIndex;
                return `<li class="option-item ${isCorrect ? 'correct' : ''}">${isCorrect ? '✓ ' : ''}${opt}</li>`;
              }).join('')}
            </ul>
            <div class="question-footer">
              <div>Từ khóa: ${q.keywords && q.keywords.length > 0 ? q.keywords.join(', ') : 'Trống'}</div>
              <button class="btn btn-danger" style="padding: 4px 8px; font-size:11px;" onclick="removeQuestion('${q._id}')">Gỡ khỏi Quiz</button>
            </div>
          </div>
        `;
      }).join('');
    }

    // Hàm bật/tắt bộ lọc câu hỏi chứa từ khoá "capital"
    function toggleCapitalFilter() {
      isFilterCapital = !isFilterCapital; // Đảo trạng thái bộ lọc
      const btn = document.getElementById('btn-filter-capital');
      if (isFilterCapital) {
        btn.classList.add('active'); // Thêm lớp active để đổi màu hiển thị của button lọc
      } else {
        btn.classList.remove('active');
      }
      fetchQuizDetails(); // Gọi lại API để tải danh sách câu hỏi đã lọc/không lọc
    }

    // Modal Control: Điều khiển hiển thị Modal thêm 1 câu hỏi mới
    function openAddQuestionModal() {
      document.getElementById('q-form').reset(); // Reset form nhập liệu
      document.getElementById('q-modal').style.display = 'flex'; // Hiển thị modal dạng flex
    }
    function closeAddQuestionModal() {
      document.getElementById('q-modal').style.display = 'none'; // Ẩn modal
    }

    // Modal Control: Điều khiển hiển thị Modal thêm hàng loạt câu hỏi dưới dạng JSON Array
    function openAddManyModal() {
      document.getElementById('many-modal').style.display = 'flex';
    }
    function closeAddManyModal() {
      document.getElementById('many-modal').style.display = 'none';
    }

    // Lắng nghe sự kiện submit form để tạo và thêm 1 câu hỏi mới vào Quiz
    document.getElementById('q-form').addEventListener('submit', function(e) {
      e.preventDefault(); // Ngăn trình duyệt reload trang
      const text = document.getElementById('q-text-input').value.trim();
      const options = [
        document.getElementById('opt-0').value.trim(),
        document.getElementById('opt-1').value.trim(),
        document.getElementById('opt-2').value.trim(),
        document.getElementById('opt-3').value.trim()
      ];
      // Lấy index của đáp án đúng được chọn
      const correctAnswerIndex = parseInt(document.querySelector('input[name="correct-opt"]:checked').value);
      
      // Xử lý chuỗi từ khóa nhập vào, tách bằng dấu phẩy
      const keywordsRaw = document.getElementById('q-keywords-input').value;
      const keywords = keywordsRaw ? keywordsRaw.split(',').map(s => s.trim()).filter(s => s) : [];

      // Gửi yêu cầu POST tạo mới và liên kết câu hỏi này vào bộ Quiz hiện tại
      fetch(`/quizzes/${quizId}/question`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, options, correctAnswerIndex, keywords })
      })
      .then(res => res.json())
      .then(res => {
        if (res.success) {
          closeAddQuestionModal(); // Đóng modal sau khi tạo thành công
          fetchQuizDetails();      // Tải lại chi tiết bộ Quiz để hiển thị câu hỏi mới
        } else {
          alert('Lỗi: ' + res.message);
        }
      });
    });

    // Lắng nghe sự kiện submit form để chèn hàng loạt câu hỏi từ JSON Array
    document.getElementById('many-form').addEventListener('submit', function(e) {
      e.preventDefault(); // Ngăn trình duyệt reload trang
      const jsonStr = document.getElementById('json-textarea').value.trim();
      let arr;
      try {
        arr = JSON.parse(jsonStr); // Chuyển chuỗi nhập vào thành đối tượng mảng JSON
        if (!Array.isArray(arr)) throw new Error('Dữ liệu nhập vào phải là mảng.');
      } catch (err) {
        alert('JSON không hợp lệ: ' + err.message);
        return;
      }

      // Gửi yêu cầu POST tạo hàng loạt câu hỏi và liên kết vào Quiz hiện tại
      fetch(`/quizzes/${quizId}/questions`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(arr)
      })
      .then(res => res.json())
      .then(res => {
        if (res.success) {
          closeAddManyModal(); // Đóng modal
          fetchQuizDetails();  // Tải lại chi tiết bộ Quiz
        } else {
          alert('Lỗi: ' + res.message);
        }
      });
    });

    // Hàm gỡ bỏ câu hỏi khỏi bộ Quiz hiện tại (chỉ gỡ liên kết ID, không xóa câu hỏi gốc)
    function removeQuestion(qId) {
      if (confirm('Bạn có chắc chắn muốn gỡ câu hỏi này khỏi Quiz?')) {
        // Tạo mảng mới loại bỏ ID câu hỏi muốn gỡ bỏ
        const updatedQuestions = quizData.questions
          .map(q => q._id)
          .filter(id => id !== qId);

        // Gọi API PUT cập nhật lại danh sách câu hỏi của Quiz
        fetch(`/quizzes/${quizId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ questions: updatedQuestions })
        })
        .then(res => res.json())
        .then(res => {
          if (res.success) {
            fetchQuizDetails(); // Tải lại chi tiết bộ Quiz
          } else {
            alert('Lỗi: ' + res.message);
          }
        });
      }
    }
  </script>
</body>
</html>
